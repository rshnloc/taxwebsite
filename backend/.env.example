# Environment
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/helpshack

# JWT
JWT_SECRET=helpshack_super_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dhirajame89@gmail.com
SMTP_PASS=your_app_password_here
FROM_EMAIL=dhirajame89@gmail.com
FROM_NAME=Helpshack

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads
